pipeline {
    agent any

    stages {

        stage('Clone Code') {
            steps {
                git branch: 'main', url: 'https://github.com/priyankakapoor12/project2.git'
            }
        }

        stage('Deploy') {
            steps {
                sh '''
                echo "Deploying HTML page..."

                sudo cp -r * /var/www/html/

                sudo systemctl restart nginx

                echo "Deployment completed"
                '''
            }
        }

    }

    post {
        success {
            echo 'HTML Deployment Successful ✅'
        }
        failure {
            echo 'HTML Deployment Failed ❌'
        }
    }
}